            <!--
                CVE overrides — these MUST come before the Spring Boot BOM
                import. Maven dependencyManagement uses first-match-wins,
                so importing netty-bom / pinning tomcat-embed-core here
                outranks Spring Boot 3.5.14's BOM which would otherwise
                pin Netty to 4.1.132.Final and Tomcat to 10.1.54 — both
                vulnerable per the 2026-06-15 dependency CVE scan
                (DEP-001, DEP-002). See security-report-2026-06-15.md.
            -->
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-bom</artifactId>
                <version>${netty.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
