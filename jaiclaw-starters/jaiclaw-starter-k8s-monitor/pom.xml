<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.jaiclaw</groupId>
        <artifactId>jaiclaw-starters</artifactId>
        <version>0.1.0</version>
    </parent>

    <artifactId>jaiclaw-starter-k8s-monitor</artifactId>
    <packaging>pom</packaging>
    <name>JaiClaw :: Starter :: K8s Monitor</name>
    <description>Kubernetes cluster monitoring assistant: Anthropic + Shell + Telegram + k8s tools + k8s-monitoring skill</description>

    <dependencies>
        <!-- Anthropic as the AI provider -->
        <dependency>
            <groupId>io.jaiclaw</groupId>
            <artifactId>jaiclaw-starter-anthropic</artifactId>
            <type>pom</type>
        </dependency>

        <!-- Spring Shell CLI interface -->
        <dependency>
            <groupId>io.jaiclaw</groupId>
            <artifactId>jaiclaw-starter-shell</artifactId>
            <type>pom</type>
        </dependency>

        <!-- Telegram channel for remote alerts and interaction -->
        <dependency>
            <groupId>io.jaiclaw</groupId>
            <artifactId>jaiclaw-channel-telegram</artifactId>
        </dependency>

        <!-- Kubernetes monitoring tools -->
        <dependency>
            <groupId>io.jaiclaw</groupId>
            <artifactId>jaiclaw-tools-k8s</artifactId>
        </dependency>

        <!-- Bundled skills (includes k8s-monitoring) -->
        <dependency>
            <groupId>io.jaiclaw</groupId>
            <artifactId>jaiclaw-skills</artifactId>
        </dependency>
    </dependencies>
</project>
