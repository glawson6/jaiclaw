end

// ============================================================================
// CALCULATE ACTUAL EIC AMOUNT
// ============================================================================

rule "Calculate EIC Amount - Phase In and Phase Out"
    salience 65
    when
        $eic : EarnedIncomeCredit(isEligible == true,
                                 creditAmount == 0,
                                 earnedIncome > 0)
    then
        BigDecimal earnedIncome = $eic.getEarnedIncome();
        BigDecimal agi = $eic.getAdjustedGrossIncome();
        BigDecimal maxCredit = $eic.getMaximumCreditAmount();
        BigDecimal earnedIncomeAmt = $eic.getEarnedIncomeAmount();
        BigDecimal thresholdPhaseout = $eic.getThresholdPhaseoutAmount();
        BigDecimal completedPhaseout = $eic.getCompletedPhaseoutAmount();

        BigDecimal credit = BigDecimal.ZERO;

        // Use the greater of earned income or AGI for phaseout calculation
        BigDecimal incomeForPhaseout = earnedIncome.max(agi);

        // Phase-in: If income is below earned income amount, credit phases in
        if (earnedIncome.compareTo(earnedIncomeAmt) <= 0) {
            // Simplified: assume maximum credit if at or above earned income amount
            // In reality, there's a phase-in percentage, but document doesn't specify
            credit = maxCredit;
        } else {
            credit = maxCredit;
        }

        // Phase-out: If income exceeds threshold, credit phases out
        if (incomeForPhaseout.compareTo(thresholdPhaseout) > 0) {
            if (incomeForPhaseout.compareTo(completedPhaseout) >= 0) {
                // Income is at or above completed phaseout - no credit
                credit = BigDecimal.ZERO;
            } else {
                // Income is in phaseout range - calculate reduced credit
                BigDecimal phaseoutRange = completedPhaseout.subtract(thresholdPhaseout);
                BigDecimal excessIncome = incomeForPhaseout.subtract(thresholdPhaseout);
                BigDecimal phaseoutPercentage = excessIncome.divide(phaseoutRange, 4, RoundingMode.HALF_UP);
                BigDecimal reduction = maxCredit.multiply(phaseoutPercentage).setScale(2, RoundingMode.HALF_UP);
                credit = maxCredit.subtract(reduction);

                if (credit.compareTo(BigDecimal.ZERO) < 0) {
                    credit = BigDecimal.ZERO;
                }
            }
        }

        $eic.setCreditAmount(credit);
        System.out.println("Calculated EIC: $" + credit + " for " + $eic.getNumberOfQualifyingChildren() + " children");
        update($eic);
end

rule "Apply EIC to Tax Return"
    salience 60
    when
        $eic : EarnedIncomeCredit(creditAmount > 0)
        $return : TaxReturn(returnId == ($eic.getCreditId().replace("-EIC", "")),
                           earnedIncomeCredit == 0)
    then
        $return.setEarnedIncomeCredit($eic.getCreditAmount());

        // EIC is fully refundable
        BigDecimal currentRefundable = $return.getRefundableCredits();
        $return.setRefundableCredits(currentRefundable.add($eic.getCreditAmount()));

        System.out.println("Applied EIC to return: $" + $eic.getCreditAmount());
        update($return);
end
