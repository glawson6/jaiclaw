        eic.setMaximumCreditAmount(new BigDecimal("8231.00"));
        eic.setEarnedIncomeAmount(new BigDecimal("18290.00"));
        eic.setThresholdPhaseoutAmount(new BigDecimal("23890.00"));
        eic.setCompletedPhaseoutAmount(new BigDecimal("62974.00"));

