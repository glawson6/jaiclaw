package io.jaiclaw.rules.tax;

import io.jaiclaw.rules.tax.facts.TaxPayer;
import io.jaiclaw.rules.tax.facts.TaxReturn;
import io.jaiclaw.rules.tax.facts.EarnedIncomeCredit;
import io.jaiclaw.rules.tax.facts.FilingStatus;
import java.math.BigDecimal;
import java.math.RoundingMode;

/**
 * Earned Income Credit (EIC) Rules for Tax Year 2026
 * Based on IRS Revenue Procedure 2025-32, Section 4.06
 * IRC Section 32 - Earned Income Credit
 *
 * Maximum credits by number of qualifying children:
 * - 0 children: $664
 * - 1 child: $4,427
 * - 2 children: $7,316
 * - 3+ children: $8,231
 */

// ============================================================================
// INVESTMENT INCOME ELIGIBILITY TEST - IRC 32(i)
// ============================================================================

rule "EIC - Investment Income Test Failure"
    salience 75
    when
        $taxpayer : TaxPayer(investmentIncome > 12200)
        $return : TaxReturn(taxPayer == $taxpayer)
        not(EarnedIncomeCredit())
    then
        // Taxpayer is not eligible for EIC due to excessive investment income
        EarnedIncomeCredit eic = new EarnedIncomeCredit();
        eic.setCreditId($return.getReturnId() + "-EIC");
        eic.setEligible(false);
        eic.setCreditAmount(BigDecimal.ZERO);
        System.out.println("EIC denied: Investment income exceeds $12,200");
        insert(eic);
end

// ============================================================================
// EIC WITH NO QUALIFYING CHILDREN
// ============================================================================

rule "EIC - No Children - Married Filing Jointly"
    salience 70
    when
        $taxpayer : TaxPayer(numberOfQualifyingChildren == 0,
                            filingStatus == FilingStatus.MARRIED_FILING_JOINTLY,
                            earnedIncome > 0,
                            investmentIncome <= 12200)
        $return : TaxReturn(taxPayer == $taxpayer)
        not(EarnedIncomeCredit())
    then
        EarnedIncomeCredit eic = new EarnedIncomeCredit();
        eic.setCreditId($return.getReturnId() + "-EIC");
        eic.setNumberOfQualifyingChildren(0);
        eic.setFilingStatus($taxpayer.getFilingStatus());
        eic.setEarnedIncome($taxpayer.getEarnedIncome());
        eic.setAdjustedGrossIncome($taxpayer.getAdjustedGrossIncome());

        // Set 2026 parameters for no children, MFJ
        eic.setMaximumCreditAmount(new BigDecimal("664.00"));
        eic.setEarnedIncomeAmount(new BigDecimal("8680.00"));
        eic.setThresholdPhaseoutAmount(new BigDecimal("18140.00"));
        eic.setCompletedPhaseoutAmount(new BigDecimal("26820.00"));

        insert(eic);
end

rule "EIC - No Children - Other Filing Status"
    salience 70
    when
        $taxpayer : TaxPayer(numberOfQualifyingChildren == 0,
                            (filingStatus != FilingStatus.MARRIED_FILING_JOINTLY),
                            earnedIncome > 0,
                            investmentIncome <= 12200)
        $return : TaxReturn(taxPayer == $taxpayer)
        not(EarnedIncomeCredit())
    then
        EarnedIncomeCredit eic = new EarnedIncomeCredit();
        eic.setCreditId($return.getReturnId() + "-EIC");
        eic.setNumberOfQualifyingChildren(0);
        eic.setFilingStatus($taxpayer.getFilingStatus());
        eic.setEarnedIncome($taxpayer.getEarnedIncome());
        eic.setAdjustedGrossIncome($taxpayer.getAdjustedGrossIncome());

        // Set 2026 parameters for no children, other filing status
        eic.setMaximumCreditAmount(new BigDecimal("664.00"));
        eic.setEarnedIncomeAmount(new BigDecimal("8680.00"));
        eic.setThresholdPhaseoutAmount(new BigDecimal("10860.00"));
        eic.setCompletedPhaseoutAmount(new BigDecimal("19540.00"));

        insert(eic);
end

