// ============================================================================
// EIC WITH THREE OR MORE QUALIFYING CHILDREN
// ============================================================================

rule "EIC - Three Plus Children - Married Filing Jointly"
    salience 70
    when
        $taxpayer : TaxPayer(numberOfQualifyingChildren >= 3,
                            filingStatus == FilingStatus.MARRIED_FILING_JOINTLY,
                            earnedIncome > 0,
                            investmentIncome <= 12200)
        $return : TaxReturn(taxPayer == $taxpayer)
        not(EarnedIncomeCredit())
    then
        EarnedIncomeCredit eic = new EarnedIncomeCredit();
        eic.setCreditId($return.getReturnId() + "-EIC");
        eic.setNumberOfQualifyingChildren($taxpayer.getNumberOfQualifyingChildren());
        eic.setFilingStatus($taxpayer.getFilingStatus());
        eic.setEarnedIncome($taxpayer.getEarnedIncome());
        eic.setAdjustedGrossIncome($taxpayer.getAdjustedGrossIncome());

        // Set 2026 parameters for 3+ children, MFJ
        eic.setMaximumCreditAmount(new BigDecimal("8231.00"));
        eic.setEarnedIncomeAmount(new BigDecimal("18290.00"));
        eic.setThresholdPhaseoutAmount(new BigDecimal("31160.00"));
        eic.setCompletedPhaseoutAmount(new BigDecimal("70244.00"));

        insert(eic);
end

