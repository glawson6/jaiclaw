package io.jaiclaw.rules.tax;

import io.jaiclaw.rules.tax.facts.TaxPayer;
import io.jaiclaw.rules.tax.facts.TaxReturn;
import io.jaiclaw.rules.tax.facts.AlternativeMinimumTax;
import io.jaiclaw.rules.tax.facts.FilingStatus;
import java.math.BigDecimal;
import java.math.RoundingMode;

/**
 * Alternative Minimum Tax (AMT) Rules for Tax Year 2026
 * Based on IRS Revenue Procedure 2025-32, Section 4.10
 * IRC Section 55 - Alternative Minimum Tax
 *
 * AMT Exemption Amounts:
 * - Joint Returns or Surviving Spouses: $140,200
 * - Unmarried Individuals: $90,100
 * - Married Filing Separately: $70,100
 * - Estates and Trusts: $31,400
 *
 * AMT Rates: 26% and 28%
 * 28% rate threshold:
 * - Married Filing Separately: $122,250
 * - All Other Taxpayers: $244,500
 */

// ============================================================================
// AMT EXEMPTION AMOUNTS - IRC 55(d)(1)
// ============================================================================

rule "AMT - Set Exemption - Married Filing Jointly"
    salience 70
    when
        $taxpayer : TaxPayer(filingStatus == FilingStatus.MARRIED_FILING_JOINTLY)
        $return : TaxReturn(taxPayer == $taxpayer)
        not(AlternativeMinimumTax())
    then
        AlternativeMinimumTax amt = new AlternativeMinimumTax();
        amt.setAmtId($return.getReturnId() + "-AMT");
        amt.setFilingStatus($taxpayer.getFilingStatus());

        // 2026 exemption for MFJ: $140,200
        amt.setExemptionAmount(new BigDecimal("140200.00"));

        // Phaseout thresholds for MFJ
        amt.setThresholdPhaseoutAmount(new BigDecimal("1000000.00"));
        amt.setCompletePhaseoutAmount(new BigDecimal("1280400.00"));

        // 28% rate threshold for MFJ
        amt.setExcessTaxableIncomeThreshold(new BigDecimal("244500.00"));

        insert(amt);
end

rule "AMT - Set Exemption - Single"
    salience 70
    when
        $taxpayer : TaxPayer(filingStatus == FilingStatus.SINGLE)
        $return : TaxReturn(taxPayer == $taxpayer)
        not(AlternativeMinimumTax())
    then
        AlternativeMinimumTax amt = new AlternativeMinimumTax();
        amt.setAmtId($return.getReturnId() + "-AMT");
        amt.setFilingStatus($taxpayer.getFilingStatus());

        // 2026 exemption for Single: $90,100
        amt.setExemptionAmount(new BigDecimal("90100.00"));

        // Phaseout thresholds for Single
        amt.setThresholdPhaseoutAmount(new BigDecimal("500000.00"));
        amt.setCompletePhaseoutAmount(new BigDecimal("680200.00"));

        // 28% rate threshold for Single
        amt.setExcessTaxableIncomeThreshold(new BigDecimal("244500.00"));

        insert(amt);
end

rule "AMT - Set Exemption - Head of Household"
    salience 70
    when
        $taxpayer : TaxPayer(filingStatus == FilingStatus.HEAD_OF_HOUSEHOLD)
