        amt.setThresholdPhaseoutAmount(new BigDecimal("500000.00"));
        amt.setCompletePhaseoutAmount(new BigDecimal("640200.00"));

        // 28% rate threshold for MFS
        amt.setExcessTaxableIncomeThreshold(new BigDecimal("122250.00"));

