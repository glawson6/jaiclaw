// ============================================================================
// MARRIED FILING SEPARATELY - IRC 1(j)(2)(D)
// ============================================================================

rule "Calculate Tax - Married Filing Separately - Bracket 1 (10%)"
    salience 100
    when
        $taxpayer : TaxPayer(filingStatus == FilingStatus.MARRIED_FILING_SEPARATELY,
                            taxableIncome > 0, taxableIncome <= 12400)
        $return : TaxReturn(taxPayer == $taxpayer, regularTax == 0)
    then
        BigDecimal tax = $taxpayer.getTaxableIncome()
                .multiply(new BigDecimal("0.10"))
                .setScale(2, RoundingMode.HALF_UP);

        $return.setRegularTax(tax);

        TaxBracketCalculation calc = new TaxBracketCalculation();
        calc.setBracketNumber(1);
        calc.setTaxRate(new BigDecimal("10"));
        calc.setIncomeInBracket($taxpayer.getTaxableIncome());
        calc.setTaxFromBracket(tax);
        calc.setBracketFloor(BigDecimal.ZERO);
        calc.setBracketCeiling(new BigDecimal("12400"));
        calc.setDescription("10% on income up to $12,400");
        $return.getBracketCalculations().add(calc);

        update($return);
end

rule "Calculate Tax - Married Filing Separately - Bracket 2 (12%)"
    salience 100
    when
        $taxpayer : TaxPayer(filingStatus == FilingStatus.MARRIED_FILING_SEPARATELY,
                            taxableIncome > 12400, taxableIncome <= 50400)
        $return : TaxReturn(taxPayer == $taxpayer, regularTax == 0)
    then
        BigDecimal baseTax = new BigDecimal("1240.00");
        BigDecimal excess = $taxpayer.getTaxableIncome().subtract(new BigDecimal("12400"));
        BigDecimal additionalTax = excess.multiply(new BigDecimal("0.12"))
                .setScale(2, RoundingMode.HALF_UP);
        BigDecimal totalTax = baseTax.add(additionalTax);

        $return.setRegularTax(totalTax);

        TaxBracketCalculation calc = new TaxBracketCalculation();
        calc.setBracketNumber(2);
        calc.setTaxRate(new BigDecimal("12"));
        calc.setIncomeInBracket(excess);
        calc.setTaxFromBracket(additionalTax);
        calc.setBracketFloor(new BigDecimal("12400"));
        calc.setBracketCeiling(new BigDecimal("50400"));
        calc.setDescription("$1,240 plus 12% of excess over $12,400");
        $return.getBracketCalculations().add(calc);

        update($return);
end

