package io.jaiclaw.rules.tax;

import io.jaiclaw.rules.tax.facts.TaxPayer;
import io.jaiclaw.rules.tax.facts.TaxReturn;
import io.jaiclaw.rules.tax.facts.FilingStatus;
import io.jaiclaw.rules.tax.facts.TaxBracketCalculation;
import java.math.BigDecimal;
import java.math.RoundingMode;

/**
 * Tax Bracket Rules for Tax Year 2026
 * Based on IRS Revenue Procedure 2025-32, Section 4.01
 * Implements 7-bracket progressive tax rates: 10%, 12%, 22%, 24%, 32%, 35%, 37%
 */

// ============================================================================
// MARRIED FILING JOINTLY AND SURVIVING SPOUSES - IRC 1(j)(2)(A)
// ============================================================================

rule "Calculate Tax - Married Filing Jointly - Bracket 1 (10%)"
    salience 100
    when
        $taxpayer : TaxPayer(filingStatus == FilingStatus.MARRIED_FILING_JOINTLY,
                            taxableIncome > 0, taxableIncome <= 24800)
        $return : TaxReturn(taxPayer == $taxpayer, regularTax == 0)
    then
        // Tax = 10% of taxable income
        BigDecimal tax = $taxpayer.getTaxableIncome()
                .multiply(new BigDecimal("0.10"))
                .setScale(2, RoundingMode.HALF_UP);

        $return.setRegularTax(tax);

        TaxBracketCalculation calc = new TaxBracketCalculation();
        calc.setBracketNumber(1);
        calc.setTaxRate(new BigDecimal("10"));
        calc.setIncomeInBracket($taxpayer.getTaxableIncome());
        calc.setTaxFromBracket(tax);
        calc.setBracketFloor(BigDecimal.ZERO);
        calc.setBracketCeiling(new BigDecimal("24800"));
        calc.setDescription("10% on income up to $24,800");
        $return.getBracketCalculations().add(calc);

        update($return);
end

rule "Calculate Tax - Married Filing Jointly - Bracket 2 (12%)"
    salience 100
    when
        $taxpayer : TaxPayer(filingStatus == FilingStatus.MARRIED_FILING_JOINTLY,
                            taxableIncome > 24800, taxableIncome <= 100800)
        $return : TaxReturn(taxPayer == $taxpayer, regularTax == 0)
    then
        // Base tax: $2,480
        // Plus 12% of excess over $24,800
        BigDecimal baseTax = new BigDecimal("2480.00");
        BigDecimal excess = $taxpayer.getTaxableIncome().subtract(new BigDecimal("24800"));
        BigDecimal additionalTax = excess.multiply(new BigDecimal("0.12"))
                .setScale(2, RoundingMode.HALF_UP);
        BigDecimal totalTax = baseTax.add(additionalTax);

        $return.setRegularTax(totalTax);

        TaxBracketCalculation calc = new TaxBracketCalculation();
        calc.setBracketNumber(2);
        calc.setTaxRate(new BigDecimal("12"));
        calc.setIncomeInBracket(excess);
        calc.setTaxFromBracket(additionalTax);
        calc.setBracketFloor(new BigDecimal("24800"));
        calc.setBracketCeiling(new BigDecimal("100800"));
        calc.setDescription("$2,480 plus 12% of excess over $24,800");
        $return.getBracketCalculations().add(calc);

        update($return);
end

