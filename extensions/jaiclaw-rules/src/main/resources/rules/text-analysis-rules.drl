package rules;

import io.jaiclaw.rules.engine.facts.TextAnalysisFact;
import io.jaiclaw.rules.engine.util.RuleLogger;

// Sentiment Analysis Rules

rule "Detect Positive Sentiment - great"
    salience 10
    activation-group "sentiment-detection"
    when
        $fact : TextAnalysisFact(sentiment == null, textLower != null, textLower matches ".*great.*")
    then
        $fact.setSentiment("positive");
        $fact.setSummary("The text expresses positive sentiment (detected 'great')");
        RuleLogger.logFact($fact);
end

