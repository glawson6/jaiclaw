rule "Detect Neutral Sentiment"
    salience 1
    activation-group "sentiment-detection"
    when
        $fact : TextAnalysisFact(sentiment == null)
    then
        $fact.setSentiment("neutral");
        $fact.setSummary("The text has neutral sentiment");
        RuleLogger.logFact($fact);
end

// Keyword Extraction Rules

rule "Extract Technology Keywords - AI"
    when
        $fact : TextAnalysisFact(textLower != null, textLower matches ".*\\bai\\b.*")
    then
        $fact.addKeyword("technology");
        $fact.addCategory("Technical Content");
end

rule "Extract Technology Keywords - Machine Learning"
    when
        $fact : TextAnalysisFact(textLower != null, textLower matches ".*machine learning.*")
