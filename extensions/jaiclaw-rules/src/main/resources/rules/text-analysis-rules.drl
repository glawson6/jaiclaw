// Text Length Analysis

rule "Analyze Short Text"
    when
        $fact : TextAnalysisFact(text.length() < 50)
    then
        $fact.addCategory("Short Message");
end

rule "Analyze Long Text"
    when
        $fact : TextAnalysisFact(text.length() > 500)
    then
        $fact.addCategory("Long Document");
end
