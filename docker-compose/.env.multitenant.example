# JaiClaw Multi-Tenant Configuration
# Copy to .env.multitenant and edit:
#   cp .env.multitenant.example .env.multitenant

# ─── LLM Provider ────────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_ENABLED=true
ANTHROPIC_API_KEY=
OPENAI_ENABLED=false
OPENAI_API_KEY=not-set
OLLAMA_ENABLED=false
GEMINI_ENABLED=false
GEMINI_API_KEY=not-set

# ─── Security ────────────────────────────────────────────────────────────────
# api-key: single shared key (simple, good for internal/dev)
# jwt: per-user tokens with tenant claims (recommended for production)
# none: no auth (development only — NOT recommended for multi-tenant)
JAICLAW_SECURITY_MODE=api-key
JAICLAW_API_KEY=

# ─── Tenant Configuration ────────────────────────────────────────────────────
# Mode is always MULTI when using start-multitenant.sh (set automatically)
# JAICLAW_TENANT_MODE=multi

# Default tenant ID — used when no X-Tenant-Id header is provided
JAICLAW_TENANT_DEFAULT_ID=default

# HTTP header for tenant resolution (rarely needs changing)
# JAICLAW_TENANT_HEADER=X-Tenant-Id

# Per-tenant config locations — comma-separated directories containing
# tenant-specific YAML files (e.g., acme-corp.yml, startup-inc.yml).
# Each file can override: agent config, model, skills, system prompt, channels.
# Prefix with file: for filesystem paths, classpath: for classpath resources.
# JAICLAW_TENANT_CONFIG_LOCATIONS=file:./config/tenants/

# ─── Channels (optional) ─────────────────────────────────────────────────────
# In multi-tenant mode, bot tokens can be mapped to tenants.
# See jaiclaw.channels.telegram.bot-token-to-tenant in application.yml.

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_ALLOWED_USERS=

SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_USE_GATEWAY=false

EMAIL_ENABLED=false
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=

SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Cron Manager (optional) ─────────────────────────────────────────────────
CRON_MANAGER_ENABLED=false
CRON_MANAGER_PORT=8090

# ─── Port Overrides ──────────────────────────────────────────────────────────
GATEWAY_PORT=8080
OLLAMA_PORT=11434
