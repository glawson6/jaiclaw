# LLM Providers (set at least one, or use Ollama alone)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama is included in the stack and always available.
# Pull a model after startup:  docker compose exec ollama ollama pull llama3.2

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Slack (optional — set APP_TOKEN for Socket Mode, or SIGNING_SECRET for webhook mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Discord (optional — set USE_GATEWAY=true for Gateway WebSocket mode)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_USE_GATEWAY=

# Port overrides
GATEWAY_PORT=8080
OLLAMA_PORT=11434
