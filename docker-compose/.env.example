# LLM Provider — set AI_PROVIDER to match your API key (anthropic, openai, or ollama)
AI_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local LLM) — set AI_PROVIDER=ollama and OLLAMA_ENABLED=true
# To start Ollama:  docker compose --profile ollama up -d
# Then pull a model: docker compose --profile ollama exec ollama ollama pull llama3.2
OLLAMA_ENABLED=false

# Telegram (optional — set TELEGRAM_ENABLED=true and provide bot token)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_ALLOWED_USERS=

# Slack (optional — set SLACK_ENABLED=true; use APP_TOKEN for Socket Mode, or SIGNING_SECRET for webhook mode)
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Discord (optional — set DISCORD_ENABLED=true; set USE_GATEWAY=true for Gateway WebSocket mode)
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_USE_GATEWAY=false

# Email (optional — set EMAIL_ENABLED=true and provide IMAP/SMTP credentials)
EMAIL_ENABLED=false
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=

# SMS via Twilio (optional — set SMS_ENABLED=true and provide Twilio credentials)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Port overrides
GATEWAY_PORT=8080
OLLAMA_PORT=11434
