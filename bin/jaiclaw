#!/usr/bin/env bash
#
# jaiclaw — Unified CLI launcher for JaiClaw
#
# Dispatches to fast-path (pure bash, no JVM) or JVM-path (jaiclaw-cli.jar)
# depending on the subcommand.
#
# Usage:
#   jaiclaw                         # interactive REPL
#   jaiclaw chat "hello"            # one-shot message
#   jaiclaw setup                   # onboard wizard
#   jaiclaw doctor                  # diagnose environment (fast-path)
#   jaiclaw version                 # print version (fast-path)
#   jaiclaw config show             # show config (fast-path)
#   jaiclaw config edit             # edit config (fast-path)
#   jaiclaw profiles list           # list profiles (fast-path)
#   jaiclaw profiles create <name>  # create profile (fast-path)
#   jaiclaw profiles switch <name>  # switch profile (fast-path)
#   jaiclaw auth status             # auth status (fast-path)
#   jaiclaw --profile work <cmd>    # use named profile
#   jaiclaw gateway start           # start gateway server
#   jaiclaw tools                   # list tools
#   jaiclaw skills                  # list skills
#   jaiclaw model list              # list models
#
# Verbosity controls (must precede subcommand):
#   jaiclaw --quiet chat "hi"            # also hide io.jaiclaw INFO (token usage, session turn)
#   jaiclaw --verbose chat "hi"          # re-enable Spring banner + framework INFO
#   jaiclaw --spring-debug chat "hi"     # Spring autoconfig conditions report (Spring's --debug)
#   jaiclaw --log-level DEBUG chat "hi"  # raw root log level override
#   Aliases: -q for --quiet, -V (capital) for --verbose. Note: -v is `version`.
#
# Secrets injection (must precede subcommand):
#   jaiclaw --use-1password chat "hi"    # re-exec under `op run --env-file=<tpl>` so
#                                          1Password-resolved secrets land as env vars
#                                          before the JVM starts. Template lives at
#                                          $JAICLAW_PROFILE_DIR/.env.op.tpl (or
#                                          $JAICLAW_HOME/.env.op.tpl for cross-profile,
#                                          or $JAICLAW_OP_ENV_TPL to override).
#   Aliases: --use-onepassword, --op.
#
set -euo pipefail

# ─── Version resolution ──────────────────────────────────────────────────────
# Read the version from the installed CLI jar's MANIFEST.MF at call time, so
# `bin/jaiclaw` doesn't need to be edited (or republished) at every release.
# Falls back to "unknown" if the jar or unzip is missing — the fast-path
# `version` command must never abort the whole script.

resolve_jaiclaw_version() {
    local jar="${JAICLAW_HOME:-$HOME/.jaiclaw}/bin/jaiclaw-cli.jar"
    if [[ ! -f "$jar" ]]; then
        echo "unknown (jar not installed)"
        return 0
    fi
    if ! command -v unzip &>/dev/null; then
        echo "unknown (unzip not on PATH)"
        return 0
    fi
    # Maven always writes META-INF/maven/<groupId>/<artifactId>/pom.properties
    # into the module jar. Spring Boot's repackage preserves this at the top
    # of the fat jar (not under BOOT-INF/). Format:
    #     artifactId=jaiclaw-cli
    #     groupId=io.jaiclaw
    #     version=0.9.3-SNAPSHOT
    local version
    version=$(unzip -p "$jar" META-INF/maven/io.jaiclaw/jaiclaw-cli/pom.properties 2>/dev/null \
        | awk -F= '/^version=/ { gsub(/\r/, "", $2); print $2; exit }')
    if [[ -z "$version" ]]; then
        # Fallback: Implementation-Version is empty in the default Spring Boot
        # repackage, but may be present if we ever wire it into the pom build.
        version=$(unzip -p "$jar" META-INF/MANIFEST.MF 2>/dev/null \
            | awk -F': ' '/^Implementation-Version:/ { gsub(/\r/, "", $2); print $2; exit }')
    fi
    if [[ -z "$version" ]]; then
        echo "unknown (no version in jar)"
        return 0
    fi
    echo "$version"
}

# ─── Colors ───────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Logging ──────────────────────────────────────────────────────────────────

info()   { printf "${CYAN}▸${NC} %s\n" "$*"; }
ok()     { printf "${GREEN}✓${NC} %s\n" "$*"; }
warn()   { printf "${YELLOW}!${NC} %s\n" "$*"; }
err()    { printf "${RED}✗${NC} %s\n" "$*" >&2; }
header() { printf "\n${BOLD}${CYAN}── %s ──${NC}\n\n" "$*"; }

# ─── Resolve JAICLAW_HOME ────────────────────────────────────────────────────

JAICLAW_HOME="${JAICLAW_HOME:-$HOME/.jaiclaw}"

# ─── Parse global flags ──────────────────────────────────────────────────────
# These flags are consumed by the launcher and translated to JVM properties or
# Spring Boot args before subcommand dispatch. They MUST appear before the
# subcommand (e.g. `jaiclaw --verbose chat hello`, not `jaiclaw chat hello --verbose`).

JAICLAW_PROFILE=""
JAICLAW_QUIET=0           # 1 = silence io.jaiclaw INFO too (truly minimal output)
JAICLAW_VERBOSE=0         # 1 = re-enable Spring framework INFO + banner
JAICLAW_SPRING_DEBUG=0    # 1 = pass Spring's --debug flag (autoconfig conditions report)
JAICLAW_LOG_LEVEL=""      # explicit root log level override (DEBUG/INFO/WARN/ERROR/TRACE)
JAICLAW_USE_1PASSWORD=0   # 1 = re-exec under `op run --env-file=<tpl>` to inject secrets

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile)
            JAICLAW_PROFILE="$2"
            shift 2
            ;;
        --profile=*)
            JAICLAW_PROFILE="${1#*=}"
            shift
            ;;
        --quiet|-q)
            JAICLAW_QUIET=1
            shift
            ;;
        --verbose|-V)
            JAICLAW_VERBOSE=1
            shift
            ;;
        --spring-debug)
            JAICLAW_SPRING_DEBUG=1
            shift
            ;;
        --log-level)
            JAICLAW_LOG_LEVEL="$2"
            shift 2
            ;;
        --log-level=*)
            JAICLAW_LOG_LEVEL="${1#*=}"
            shift
            ;;
        --use-1password|--use-onepassword|--op)
            JAICLAW_USE_1PASSWORD=1
            shift
            ;;
        *)
            break
            ;;
    esac
done

# ─── Resolve active profile ──────────────────────────────────────────────────

resolve_profile() {
    # Explicit flag takes precedence
    if [[ -n "$JAICLAW_PROFILE" ]]; then
        echo "$JAICLAW_PROFILE"
        return
    fi

    # Check env var
    if [[ -n "${JAICLAW_PROFILE:-}" ]]; then
        echo "$JAICLAW_PROFILE"
        return
    fi

    # Read from config.yaml
    local config_file="$JAICLAW_HOME/config.yaml"
    if [[ -f "$config_file" ]]; then
        local profile
        profile=$(grep '^active-profile:' "$config_file" 2>/dev/null | awk '{print $2}' | tr -d '[:space:]')
        if [[ -n "$profile" ]]; then
            echo "$profile"
            return
        fi
    fi

    echo "default"
}

ACTIVE_PROFILE=$(resolve_profile)
JAICLAW_PROFILE_DIR="$JAICLAW_HOME/profiles/$ACTIVE_PROFILE"

# ─── 1Password wrap: re-exec under `op run` if requested ─────────────────────
#
# When --use-1password is set AND we're not already inside an op-run-
# driven invocation, look for a template that lists every secret as
# `KEY=op://vault/item/field` lines. Re-exec under `op run --env-file`
# so injected env vars arrive BEFORE the per-profile .env source below.
# The .env's "only set if not already in env" semantics then make the
# op-resolved values win over any literal value in the .env, which is
# what we want.

if [[ $JAICLAW_USE_1PASSWORD -eq 1 && -z "${JAICLAW_OP_RUN_ACTIVE:-}" ]]; then
    # Search precedence:
    #   1. $JAICLAW_OP_ENV_TPL (operator override)
    #   2. $JAICLAW_PROFILE_DIR/.env.op.tpl (per-profile sibling of .env)
    #   3. $JAICLAW_HOME/.env.op.tpl (cross-profile default)
    OP_TPL="${JAICLAW_OP_ENV_TPL:-}"
    if [[ -z "$OP_TPL" && -f "$JAICLAW_PROFILE_DIR/.env.op.tpl" ]]; then
        OP_TPL="$JAICLAW_PROFILE_DIR/.env.op.tpl"
    fi
    if [[ -z "$OP_TPL" && -f "$JAICLAW_HOME/.env.op.tpl" ]]; then
        OP_TPL="$JAICLAW_HOME/.env.op.tpl"
    fi

    if [[ -z "$OP_TPL" || ! -f "$OP_TPL" ]]; then
        err "--use-1password: no template found."
        echo "  Expected one of:"
        echo "    \$JAICLAW_OP_ENV_TPL                                (override)"
        echo "    $JAICLAW_PROFILE_DIR/.env.op.tpl    (next to your profile .env)"
        echo "    $JAICLAW_HOME/.env.op.tpl                           (cross-profile)"
        echo ""
        echo "  Template format (one KEY=op://... per line):"
        echo "    ANTHROPIC_API_KEY=op://TapTech-Security/MiniMax-Anthropic-API/anthropic-api-key"
        echo ""
        echo "  See docs/user/PRODUCTION-DEPLOYMENT.md §3.1.1 for the reference layout."
        exit 1
    fi

    if ! command -v op >/dev/null 2>&1; then
        err "--use-1password: 'op' CLI not found in PATH."
        echo "  Install: https://developer.1password.com/docs/cli/get-started/"
        exit 1
    fi

    # Rebuild the original arg list MINUS --use-1password (which would
    # otherwise re-trigger this block on the next invocation). The
    # surviving global flags get prepended; positional subcommand args
    # are still in $@ because the flag-parser left them in place.
    REEXEC_FLAGS=()
    [[ -n "$JAICLAW_PROFILE"        ]] && REEXEC_FLAGS+=("--profile" "$JAICLAW_PROFILE")
    [[ $JAICLAW_QUIET -eq 1         ]] && REEXEC_FLAGS+=("--quiet")
    [[ $JAICLAW_VERBOSE -eq 1       ]] && REEXEC_FLAGS+=("--verbose")
    [[ $JAICLAW_SPRING_DEBUG -eq 1  ]] && REEXEC_FLAGS+=("--spring-debug")
    [[ -n "$JAICLAW_LOG_LEVEL"      ]] && REEXEC_FLAGS+=("--log-level" "$JAICLAW_LOG_LEVEL")

    info "Re-executing under 'op run' using $OP_TPL"
    export JAICLAW_OP_RUN_ACTIVE=1
    exec op run --env-file="$OP_TPL" -- "$0" "${REEXEC_FLAGS[@]}" "$@"
fi

# ─── Source profile .env ──────────────────────────────────────────────────────

if [[ -f "$JAICLAW_PROFILE_DIR/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$JAICLAW_PROFILE_DIR/.env"
    set +a
fi

# ─── Resolve Java ─────────────────────────────────────────────────────────────

resolve_java() {
    # 1. Explicit JAVA_HOME
    if [[ -n "${JAVA_HOME:-}" ]] && [[ -x "$JAVA_HOME/bin/java" ]]; then
        echo "$JAVA_HOME/bin/java"
        return
    fi

    # 2. SDKMAN
    if [[ -x "$HOME/.sdkman/candidates/java/current/bin/java" ]]; then
        echo "$HOME/.sdkman/candidates/java/current/bin/java"
        return
    fi

    # 3. PATH
    if command -v java &>/dev/null; then
        command -v java
        return
    fi

    return 1
}

# ─── Resolve CLI JAR ─────────────────────────────────────────────────────────

resolve_jar() {
    # 0. Explicit override (e.g., Docker containers)
    if [[ -n "${JAICLAW_CLI_JAR:-}" ]] && [[ -f "$JAICLAW_CLI_JAR" ]]; then
        echo "$JAICLAW_CLI_JAR"
        return
    fi

    # 1. Installed JAR in JAICLAW_HOME
    if [[ -f "$JAICLAW_HOME/bin/jaiclaw-cli.jar" ]]; then
        echo "$JAICLAW_HOME/bin/jaiclaw-cli.jar"
        return
    fi

    # 2. Co-located JAR (same directory as the launcher script)
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [[ -f "$script_dir/jaiclaw-cli.jar" ]]; then
        echo "$script_dir/jaiclaw-cli.jar"
        return
    fi

    # 3. Development mode — look for built JAR relative to this script
    local project_root
    project_root="$(cd "$script_dir/.." && pwd)"

    local target_dir="$project_root/apps/jaiclaw-cli/target"
    if [[ -d "$target_dir" ]]; then
        local jar
        jar=$(find "$target_dir" -maxdepth 1 -name "jaiclaw-cli-*.jar" ! -name "*-original*" -type f 2>/dev/null | head -1)
        if [[ -n "$jar" ]]; then
            echo "$jar"
            return
        fi
    fi

    return 1
}

# ─── Fast-path commands (no JVM) ─────────────────────────────────────────────

cmd_version() {
    echo "jaiclaw $(resolve_jaiclaw_version)"
}

cmd_doctor() {
    echo "JaiClaw Doctor"
    echo "=============="
    echo ""

    # Java
    if JAVA_BIN=$(resolve_java 2>/dev/null); then
        local java_ver
        java_ver=$("$JAVA_BIN" -version 2>&1 | head -1)
        ok "Java:           $java_ver"
    else
        err "Java:           not found"
    fi

    # JAICLAW_HOME
    if [[ -d "$JAICLAW_HOME" ]]; then
        ok "JAICLAW_HOME:   $JAICLAW_HOME"
    else
        warn "JAICLAW_HOME:   $JAICLAW_HOME (not created yet)"
    fi

    # Active profile
    info "Profile:        $ACTIVE_PROFILE"

    # Config files
    local config_file="$JAICLAW_PROFILE_DIR/application-local.yml"
    if [[ -f "$config_file" ]]; then
        ok "Config:         $config_file"
    else
        warn "Config:         $config_file (missing)"
    fi

    local env_file="$JAICLAW_PROFILE_DIR/.env"
    if [[ -f "$env_file" ]]; then
        ok "Env file:       $env_file"
    else
        warn "Env file:       $env_file (missing)"
    fi

    # CLI JAR
    if JAR_PATH=$(resolve_jar 2>/dev/null); then
        ok "CLI JAR:        $JAR_PATH"
    else
        warn "CLI JAR:        not found (build with: ./mvnw package -pl :jaiclaw-cli -am -DskipTests)"
    fi

    echo ""
    echo "LLM Providers:"

    # API keys
    check_env_key "Anthropic" "ANTHROPIC_API_KEY"
    check_env_key "OpenAI"    "OPENAI_API_KEY"
    check_env_key "Gemini"    "GEMINI_API_KEY"
    check_env_key "Bedrock"   "AWS_ACCESS_KEY_ID"

    # Ollama
    local ollama_url="${OLLAMA_BASE_URL:-http://localhost:11434}"
    if curl -s -o /dev/null --connect-timeout 2 "$ollama_url" 2>/dev/null; then
        ok "  Ollama:       reachable at $ollama_url"
    else
        warn "  Ollama:       not reachable at $ollama_url"
    fi

    echo ""
    echo "Channels:"
    check_env_key "Telegram" "TELEGRAM_BOT_TOKEN"
    check_env_key "Slack"    "SLACK_BOT_TOKEN"
    check_env_key "Discord"  "DISCORD_BOT_TOKEN"

    echo ""
    echo "External:"
    # Docker
    if docker_ver=$(docker version --format '{{.Server.Version}}' 2>/dev/null); then
        ok "  Docker:       v$docker_ver"
    else
        warn "  Docker:       not available"
    fi
}

check_env_key() {
    local label="$1"
    local var_name="$2"
    local value="${!var_name:-}"
    if [[ -n "$value" && "$value" != "not-set" ]]; then
        printf "  ${GREEN}[ok]${NC} %-13s configured\n" "$label:"
    else
        printf "  ${DIM}[--]${NC} %-13s not configured\n" "$label:"
    fi
}

cmd_config_show() {
    local config_file="$JAICLAW_PROFILE_DIR/application-local.yml"
    if [[ -f "$config_file" ]]; then
        echo "# Profile: $ACTIVE_PROFILE"
        echo "# File: $config_file"
        echo ""
        cat "$config_file"
    else
        warn "No config file found at $config_file"
        echo "Run 'jaiclaw setup' to create one."
    fi
}

cmd_config_edit() {
    local config_file="$JAICLAW_PROFILE_DIR/application-local.yml"
    if [[ ! -f "$config_file" ]]; then
        mkdir -p "$JAICLAW_PROFILE_DIR"
        echo "# JaiClaw configuration — profile: $ACTIVE_PROFILE" > "$config_file"
    fi
    local editor="${EDITOR:-${VISUAL:-vi}}"
    exec "$editor" "$config_file"
}

cmd_profiles_list() {
    local profiles_dir="$JAICLAW_HOME/profiles"
    if [[ ! -d "$profiles_dir" ]]; then
        warn "No profiles directory found at $profiles_dir"
        echo "Run 'jaiclaw profiles create <name>' to create one."
        return
    fi

    echo "Profiles ($profiles_dir)"
    echo "─────────────────────────"

    for dir in "$profiles_dir"/*/; do
        [[ ! -d "$dir" ]] && continue
        local name
        name=$(basename "$dir")
        local marker="  "
        [[ "$name" == "$ACTIVE_PROFILE" ]] && marker=" *"

        local has_yml="---"
        [[ -f "$dir/application-local.yml" ]] && has_yml="yml"
        local has_env="---"
        [[ -f "$dir/.env" ]] && has_env="env"

        printf "%s %-20s [%s %s]\n" "$marker" "$name" "$has_yml" "$has_env"
    done
}

cmd_profiles_create() {
    local name="$1"
    local profile_dir="$JAICLAW_HOME/profiles/$name"

    if [[ -d "$profile_dir" ]]; then
        err "Profile already exists: $name"
        return 1
    fi

    mkdir -p "$profile_dir/sessions"

    cat > "$profile_dir/application-local.yml" <<YAML
# JaiClaw configuration — profile: $name
# Edit this file to configure your LLM provider and other settings.
jaiclaw:
  identity:
    name: JaiClaw
  security:
    mode: none

spring:
  ai:
    anthropic:
      api-key: \${ANTHROPIC_API_KEY:not-set}
YAML

    cat > "$profile_dir/.env" <<ENV
# JaiClaw secrets — profile: $name
# Source this file before running JaiClaw: source $profile_dir/.env

# export ANTHROPIC_API_KEY=sk-ant-...
# export OPENAI_API_KEY=sk-...
ENV

    ok "Created profile: $name"
    echo "  Location: $profile_dir"
    echo "  Run 'jaiclaw --profile $name setup' to configure it."
}

cmd_profiles_switch() {
    local name="$1"
    local profile_dir="$JAICLAW_HOME/profiles/$name"

    if [[ ! -d "$profile_dir" ]]; then
        err "Profile not found: $name"
        echo "Use 'jaiclaw profiles create $name' first."
        return 1
    fi

    local config_file="$JAICLAW_HOME/config.yaml"
    cat > "$config_file" <<YAML
# JaiClaw CLI config
active-profile: $name
YAML

    ok "Switched to profile: $name"
    echo "  Config dir: $profile_dir"
}

cmd_auth_status() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local auth_script="$script_dir/../scripts/auth-status.sh"

    if [[ -x "$auth_script" ]]; then
        exec "$auth_script" "${1:-full}"
    else
        err "Auth status script not found at $auth_script"
        echo "Run from the JaiClaw project directory, or install auth-status.sh."
        return 1
    fi
}

# ─── 1Password setup wizard (fast-path, pre-JVM) ─────────────────────────────
#
# Walks the operator through writing a `.env.op.tpl` template for a
# JaiClaw profile. The template is a list of `KEY=op://vault/item/field`
# lines — `op run --env-file=<tpl>` resolves them at startup. Combined
# with the `--use-1password` flag, this lets JaiClaw read secrets from
# 1Password without ever touching plaintext on disk after install.
#
# Strict no-leakage rules followed by this command:
#
#   1. Never prints any value from the existing .env to stdout/stderr.
#      Only key names are displayed.
#   2. Never writes the operator's vault/item/field choices anywhere
#      except into the template (which contains references only).
#   3. Never asks for or stores a 1Password service-account token. The
#      operator authenticates via `op signin` independently.
#   4. Leaves the existing .env in place. Migration is additive.
#   5. The smoke test uses `op run --env-file=<tmp> -- env` and pipes
#      that output through grep -c so individual values never reach
#      this script's stdout.
#
cmd_setup_1password() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    header "JaiClaw 1Password setup"

    # ── Preflight ───────────────────────────────────────────────────────
    if ! command -v op >/dev/null 2>&1; then
        err "1Password CLI ('op') not found in PATH."
        echo "Install: https://developer.1password.com/docs/cli/get-started/"
        return 1
    fi
    info "Detected: $(op --version 2>/dev/null) (1Password CLI)"

    if ! op vault list >/dev/null 2>&1; then
        warn "Not signed in to 1Password CLI."
        echo "  Run 'op signin' (or 'eval \$(op signin)') first, then re-run this command."
        echo "  This script never asks for or stores any token."
        return 1
    fi

    # ── Resolve target profile + env files ─────────────────────────────
    local profile_dir="${JAICLAW_PROFILE_DIR:-$JAICLAW_HOME/profiles/default}"
    local env_file="$profile_dir/.env"
    local op_tpl="$profile_dir/.env.op.tpl"

    if [[ ! -f "$env_file" ]]; then
        warn "No existing .env at $env_file."
        info "Creating a fresh template — you'll add keys interactively below."
        mkdir -p "$profile_dir"
        : > "$env_file"
    fi

    info "Target profile dir: $profile_dir"
    if [[ -f "$op_tpl" ]]; then
        info "Existing template found at $op_tpl — entries will be merged."
    fi

    # ── Vault + item defaults ──────────────────────────────────────────
    # Generic defaults only. No org-specific names baked into this
    # public script. Operators with a standard vault should
    # `export JAICLAW_OP_DEFAULT_VAULT=MyVault` before running.
    local default_vault="${JAICLAW_OP_DEFAULT_VAULT:-<your-vault>}"
    local default_item="${JAICLAW_OP_DEFAULT_ITEM:-<your-item>}"

    printf '%s' "  Vault name [${default_vault}]: " >&2
    local vault
    read -r vault
    vault="${vault:-$default_vault}"

    if [[ "$vault" == "<your-vault>" ]]; then
        err "Vault name required. Set JAICLAW_OP_DEFAULT_VAULT or type a name."
        return 1
    fi

    # ── Enumerate keys present in the existing .env (names only) ──────
    local -a env_keys=()
    if [[ -s "$env_file" ]]; then
        while IFS='=' read -r key _value; do
            [[ "$key" =~ ^[[:space:]]*# ]] && continue
            [[ -z "$key" ]] && continue
            env_keys+=("$key")
        done <"$env_file"
    fi

    echo
    if [[ ${#env_keys[@]} -eq 0 ]]; then
        info "Existing .env has no keys. You'll add references by name below."
    else
        info "Existing .env contains ${#env_keys[@]} key(s):"
        local i
        for i in "${!env_keys[@]}"; do
            printf "    [%d] %s\n" "$((i+1))" "${env_keys[$i]}"
        done
        echo
        info "Pick keys to migrate. Enter numbers separated by spaces,"
        info "or 'all' to migrate everything, or 'none' to add new keys"
        info "by name only."
        printf '%s' "  Selection: " >&2
    fi

    local -a chosen_keys=()
    if [[ ${#env_keys[@]} -gt 0 ]]; then
        local picks
        read -r picks
        case "$picks" in
            all|ALL|"")
                chosen_keys=("${env_keys[@]}")
                ;;
            none|NONE)
                ;;
            *)
                local n
                for n in $picks; do
                    if [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= ${#env_keys[@]} )); then
                        chosen_keys+=("${env_keys[$((n-1))]}")
                    fi
                done
                ;;
        esac
    fi

    # ── Optional: add brand-new keys (not in .env) ─────────────────────
    echo
    info "Add additional keys (not currently in .env)? Enter one KEY per line."
    info "Empty line when done."
    while true; do
        printf '%s' "  Key name: " >&2
        local extra
        read -r extra
        [[ -z "$extra" ]] && break
        chosen_keys+=("$extra")
    done

    if [[ ${#chosen_keys[@]} -eq 0 ]]; then
        warn "Nothing to migrate. Exiting."
        return 0
    fi

    # ── Per-key item/field mapping ─────────────────────────────────────
    echo
    info "Mapping ${#chosen_keys[@]} key(s) to 1Password references."
    info "Hit Enter to accept defaults; everything is shown so you can"
    info "review before writing."
    echo

    local -A mapping=()  # KEY -> "op://vault/item/field"
    local k default_field
    for k in "${chosen_keys[@]}"; do
        # Heuristic for field default: lowercase the key, replace '_' with '-'
        default_field="$(printf '%s' "$k" | tr '[:upper:]_' '[:lower:]-')"

        printf '  %s\n' "$k"
        printf '%s' "    item  [${default_item}]: " >&2
        local item
        read -r item
        item="${item:-$default_item}"

        printf '%s' "    field [${default_field}]: " >&2
        local field
        read -r field
        field="${field:-$default_field}"

        if [[ "$item" == "<your-item>" ]]; then
            warn "    Skipping $k — no item specified."
            continue
        fi
        mapping["$k"]="op://${vault}/${item}/${field}"
        echo
    done

    if [[ ${#mapping[@]} -eq 0 ]]; then
        warn "No mappings to write. Exiting."
        return 0
    fi

    # ── Smoke test against a temp template ─────────────────────────────
    local tmp_tpl
    tmp_tpl="$(mktemp -t jaiclaw-op-tpl.XXXXXX)" || {
        err "Cannot create temp file."
        return 1
    }
    trap 'rm -f "$tmp_tpl"' RETURN

    for k in "${!mapping[@]}"; do
        printf '%s=%s\n' "$k" "${mapping[$k]}" >>"$tmp_tpl"
    done

    info "Smoke test: resolving all ${#mapping[@]} references via 'op run'"
    info "(values are piped to grep -c — none reach this script's stdout)"

    local resolved_count
    if resolved_count="$(op run --env-file="$tmp_tpl" -- env 2>/dev/null \
                       | grep -cE "^($(IFS='|'; echo "${!mapping[*]}"))=" 2>/dev/null)"; then
        if (( resolved_count == ${#mapping[@]} )); then
            ok "All ${#mapping[@]} references resolved cleanly."
        else
            warn "Only $resolved_count of ${#mapping[@]} references resolved."
            warn "Some op:// paths may point at missing items/fields."
            printf '%s' "  Write template anyway? [y/N]: " >&2
            local conf
            read -r conf
            if [[ "$conf" != "y" && "$conf" != "Y" ]]; then
                info "Aborted. Nothing written."
                return 0
            fi
        fi
    else
        err "Smoke test failed — 'op run' returned non-zero."
        echo "  Check that you're signed in ('op vault list') and that the vault"
        echo "  name is correct. Nothing written."
        return 1
    fi

    # ── Merge into the persistent template ─────────────────────────────
    local backup=""
    if [[ -f "$op_tpl" ]]; then
        backup="${op_tpl}.bak.$(date +%s)"
        cp "$op_tpl" "$backup"
        info "Backed up existing template to $backup"
    fi

    # Build merged file. Existing entries we're not overwriting stay;
    # any entry whose key matches a new one gets replaced.
    local merged
    merged="$(mktemp -t jaiclaw-op-merged.XXXXXX)" || return 1
    if [[ -f "$op_tpl" ]]; then
        while IFS='=' read -r key value; do
            [[ "$key" =~ ^[[:space:]]*# ]] && { printf '%s=%s\n' "$key" "$value" >>"$merged"; continue; }
            [[ -z "$key" ]] && { echo "" >>"$merged"; continue; }
            if [[ -z "${mapping[$key]:-}" ]]; then
                printf '%s=%s\n' "$key" "$value" >>"$merged"
            fi
        done <"$op_tpl"
    else
        cat >>"$merged" <<EOF
# JaiClaw 1Password template — generated by 'jaiclaw setup-1password'
# Format: KEY=op://<vault>/<item>/<field>
# Resolved at startup via: jaiclaw --use-1password <command>
# This file contains REFERENCES only. Safe to commit to a private repo.
EOF
    fi
    for k in "${!mapping[@]}"; do
        printf '%s=%s\n' "$k" "${mapping[$k]}" >>"$merged"
    done

    mv "$merged" "$op_tpl"
    ok "Wrote ${#mapping[@]} reference(s) to $op_tpl"

    # ── Closing guidance — do NOT touch the existing .env ──────────────
    echo
    info "Existing plaintext keys for the migrated names are still in:"
    info "  $env_file"
    info "Recommended: after a successful 'jaiclaw --use-1password' run,"
    info "comment out (or delete) those lines manually. The launcher's"
    info "'only set if not already in env' semantics mean op-resolved"
    info "values already win over .env literals — so the migration is"
    info "non-destructive in either direction."
    echo
    info "Try it now:"
    echo "    jaiclaw --use-1password chat \"hello\""
}

# ─── JVM-path dispatch ───────────────────────────────────────────────────────

run_jvm() {
    local JAVA_BIN
    JAVA_BIN=$(resolve_java) || {
        err "Java not found. Install Java 21+ via SDKMAN: sdk install java 21.0.9-oracle"
        exit 1
    }

    local JAR_PATH
    JAR_PATH=$(resolve_jar) || {
        err "jaiclaw-cli JAR not found."
        echo "Build it with: ./mvnw package -pl :jaiclaw-cli -am -DskipTests"
        echo "Or install to: $JAICLAW_HOME/bin/jaiclaw-cli.jar"
        exit 1
    }

    local JVM_OPTS=()

    # Profile directory for Spring config import
    JVM_OPTS+=("-DJAICLAW_PROFILE_DIR=$JAICLAW_PROFILE_DIR")

    # Lazy init for read-only commands (faster startup)
    case "${1:-}" in
        tools|skills|status|model|model-list|model-show|profile|profile-list|profile-show|config|doctor)
            JVM_OPTS+=("-Dspring.main.lazy-initialization=true")
            ;;
    esac

    # CDS archive if available
    local CDS_ARCHIVE="$JAICLAW_HOME/bin/jaiclaw-cli.jsa"
    if [[ -f "$CDS_ARCHIVE" ]]; then
        JVM_OPTS+=("-XX:SharedArchiveFile=$CDS_ARCHIVE")
    fi

    # ─── Verbosity controls ──────────────────────────────────────────────────
    # application.yml is the quiet baseline (banner off, framework loggers WARN,
    # io.jaiclaw at INFO). Flags below override it from the launcher side so the
    # same jar serves all verbosity modes.

    if [[ $JAICLAW_QUIET -eq 1 ]]; then
        JVM_OPTS+=("-Dlogging.level.io.jaiclaw=WARN")
    fi

    if [[ $JAICLAW_VERBOSE -eq 1 ]]; then
        JVM_OPTS+=("-Dspring.main.banner-mode=console")
        JVM_OPTS+=("-Dspring.main.log-startup-info=true")
        JVM_OPTS+=("-Dlogging.level.root=INFO")
        JVM_OPTS+=("-Dlogging.level.org.springframework=INFO")
        JVM_OPTS+=("-Dlogging.level.com.embabel=INFO")
        JVM_OPTS+=("-Dlogging.level.org.apache.camel=INFO")
    fi

    if [[ -n "$JAICLAW_LOG_LEVEL" ]]; then
        # Override root AND io.jaiclaw — application.yml pins io.jaiclaw at INFO,
        # which would otherwise win over a root override and hide JaiClaw DEBUG.
        JVM_OPTS+=("-Dlogging.level.root=$JAICLAW_LOG_LEVEL")
        JVM_OPTS+=("-Dlogging.level.io.jaiclaw=$JAICLAW_LOG_LEVEL")
    fi

    # Spring Boot's --debug flag prints the autoconfig conditions report.
    # We pass it as a JVM property (`-Ddebug=true`) rather than a CLI arg
    # because Spring Shell's NonInteractiveShellRunner concatenates ALL args
    # into the command name — so `... -jar JAR --debug tools` becomes a lookup
    # for the command literally named "--debug tools", which fails. The system
    # property is read by Spring Boot's Environment identically to the CLI arg.
    #
    # The report is emitted by org.springframework.boot.autoconfigure at DEBUG.
    # Our application.yml pins that logger to WARN, so we explicitly raise it
    # here too — otherwise -Ddebug=true has no visible effect.
    if [[ $JAICLAW_SPRING_DEBUG -eq 1 ]]; then
        JVM_OPTS+=("-Ddebug=true")
        JVM_OPTS+=("-Dlogging.level.org.springframework.boot.autoconfigure=DEBUG")
    fi

    exec "$JAVA_BIN" "${JVM_OPTS[@]}" -jar "$JAR_PATH" "$@"
}

# ─── Main dispatch ────────────────────────────────────────────────────────────

SUBCOMMAND="${1:-}"

case "$SUBCOMMAND" in
    "")
        # No subcommand — launch interactive REPL
        run_jvm
        ;;
    version|--version|-v)
        cmd_version
        ;;
    doctor|doc)
        cmd_doctor
        ;;
    config)
        shift
        SUB="${1:-show}"
        case "$SUB" in
            show)   cmd_config_show ;;
            edit)   cmd_config_edit ;;
            *)      err "Unknown config command: $SUB"; echo "Usage: jaiclaw config show|edit" ;;
        esac
        ;;
    profiles)
        shift
        SUB="${1:-list}"
        case "$SUB" in
            list)           cmd_profiles_list ;;
            create)         cmd_profiles_create "${2:?Profile name required}" ;;
            switch)         cmd_profiles_switch "${2:?Profile name required}" ;;
            *)              err "Unknown profiles command: $SUB"; echo "Usage: jaiclaw profiles list|create|switch <name>" ;;
        esac
        ;;
    auth)
        shift
        SUB="${1:-status}"
        case "$SUB" in
            status) cmd_auth_status "${2:-full}" ;;
            *)      run_jvm auth "$@" ;;
        esac
        ;;
    setup-1password|onepassword-setup)
        cmd_setup_1password
        ;;
    # JVM-path commands
    chat|setup|onboard|gateway|gateway-start|gateway-stop|gateway-status|\
    tools|skills|status|models|login|logout|\
    model|model-list|model-show|\
    profile|profile-list|profile-create|profile-switch|profile-show|\
    sessions|session-history|new-session)
        run_jvm "$@"
        ;;
    help|--help|-h)
        cat <<'HELP'
JaiClaw CLI — Unified command-line interface

Usage: jaiclaw [--profile <name>] <command> [args]

Fast commands (no JVM):
  version                   Print version
  doctor                    Diagnose environment
  config show               Show current config
  config edit               Edit config in $EDITOR
  profiles list             List profiles
  profiles create <name>    Create a new profile
  profiles switch <name>    Switch active profile
  auth status               Show auth profile status
  setup-1password           Wizard: write .env.op.tpl for `op run` injection

JVM commands:
  chat <message>            Send a message (or start REPL)
  setup / onboard           Interactive setup wizard
  gateway start [--port N]  Start gateway server
  gateway stop              Stop gateway server
  gateway status            Check gateway status
  tools                     List registered tools
  skills                    List loaded skills
  status                    Show system status
  models                    Show configured providers
  model list                List providers and models
  model show                Show active model
  login [provider]          OAuth login
  auth status/rotate/pin    Auth management

Global options:
  --profile <name>          Use named profile (default: from config.yaml)

Environment:
  JAICLAW_HOME              Base directory (default: ~/.jaiclaw)
  JAICLAW_PROFILE           Override active profile
  JAVA_HOME                 Java installation directory
HELP
        ;;
    *)
        err "Unknown command: $SUBCOMMAND"
        echo "Run 'jaiclaw help' for usage."
        exit 1
        ;;
esac
